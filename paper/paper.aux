\@writefile{lof}{\contentsline {figure}{\numberline {1}{\ignorespaces \textit  {Paired} training data (left) consists of training examples $\{x_i, y_i\}_{i=1}^N$. \textit  {Unpaired} training data (right) consists of a source set $\{x_i\}_{i=1}^N$ ($x_i \in X$) and a target set $\{y_i\}_{i=1}^N$ ($y_i \in Y$). Unpaired training contains no correspondence from the source set $X$ to the target set $Y$. Figure adapted from \blx@tocontentsinit {0}\cite {zhuUnpairedImagetoImageTranslation2020}.}}{2}{figure.1}\protected@file@percent }
\newlabel{fig:paired-unpaired}{{1}{2}{\textit {Paired} training data (left) consists of training examples $\{x_i, y_i\}_{i=1}^N$. \textit {Unpaired} training data (right) consists of a source set $\{x_i\}_{i=1}^N$ ($x_i \in X$) and a target set $\{y_i\}_{i=1}^N$ ($y_i \in Y$). Unpaired training contains no correspondence from the source set $X$ to the target set $Y$. Figure adapted from \cite {zhuUnpairedImagetoImageTranslation2020}}{figure.1}{}}
